{
    "name": "@kylinbits/theme",
    "version": "1.0.7",
    "repository": {
        "type": "git",
        "url": "https://github.com/zhangfisher/kylinbits.git"
    },
    "files": [
        "dist",
        "readme.md"
    ],
    "type": "module",
    "module": "src/index.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "browser": "./dist/index.global.js"
        },
        "./global": {
            "import": "./dist/index.global.js",
            "require": "./dist/index.global.js"
        },
        "./index.css": {
            "import": "./dist/index.css",
            "require": "./dist/index.css"
        },
        "./themes/*.css": {
            "import": "./dist/*.css",
            "require": "./dist/*.css"
        }
    },
    "scripts": {
        "dev": "vite",
        "storybook": "storybook dev -p 6006 --no-open",
        "build": "bun run build:css && tsup",
        "build:css": "lessc src/styles/index.less dist/index.css",
        "build:storybook": "storybook build"
    },
    "dependencies": {
        "@ant-design/fast-color": "^3.0.0",
        "@yosulramp/material-color-palette-js": "^1.0.4"
    },
    "devDependencies": {
        "@storybook/addon-docs": "^9.1.20",
        "@storybook/web-components-vite": "^9.1.20",
        "@swc/core": "^1.15.21",
        "@types/bun": "1.3.11",
        "esbuild-copy-files-plugin": "^1.2.1",
        "less": "^4.6.4",
        "storybook": "^9.1.20",
        "tsup": "^8.5.1",
        "typescript": "^6.0.2",
        "vanilla-picker": "^2.12.3",
        "vite": "^8.0.3",
        "vite-plugin-cp": "^6.0.3"
    },
    "packageManager": "^bun@1.3.6"
}
